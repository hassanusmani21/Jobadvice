generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  learner
  admin
}

enum LearnProgressStatus {
  not_started
  in_progress
  completed
}

enum LearnSubmissionStatus {
  queued
  running
  passed
  failed
  error
}

model User {
  id          String            @id @default(cuid())
  name        String?
  email       String?           @unique
  emailVerified DateTime?
  image       String?
  role        UserRole          @default(learner)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lastSeenAt  DateTime?
  accounts    Account[]
  sessions    Session[]
  progress    LearnProgress[]
  drafts      LearnSavedDraft[]
  submissions LearnSubmission[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LearnProgress {
  id                  String              @id @default(cuid())
  userId              String
  trackSlug           String
  courseSlug          String
  lessonSlug          String
  status              LearnProgressStatus @default(not_started)
  percentComplete     Int                 @default(0)
  bestMcqScore        Int?
  bestAssignmentScore Int?
  lastOpenedAt        DateTime?
  completedAt         DateTime?
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonSlug])
}

model LearnSavedDraft {
  id             String   @id @default(cuid())
  userId         String
  assignmentSlug String
  language       String
  filesJson      Json
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentSlug, language])
}

model LearnSubmission {
  id             String                @id @default(cuid())
  userId         String
  assignmentSlug String
  lessonSlug     String
  language       String
  status         LearnSubmissionStatus @default(queued)
  score          Int                   @default(0)
  passedCount    Int                   @default(0)
  totalCount     Int                   @default(0)
  runtimeMs      Int?
  filesJson      Json
  createdAt      DateTime              @default(now())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assignmentSlug])
}
