# Local development example

# Auth
AUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://jobadvice.in
ALLOWED_ADMIN_EMAILS=you@example.com
NO_EXPIRY_JOB_RETENTION_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Decap GitHub OAuth
DECAP_GITHUB_CLIENT_ID=your-decap-github-client-id
DECAP_GITHUB_CLIENT_SECRET=your-decap-github-client-secret

# Ollama AI extraction
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_NUM_CTX=768
OLLAMA_TIMEOUT_MS=60000
OLLAMA_MAX_SOURCE_CHARS=6000
OLLAMA_NUM_PREDICT=260
OLLAMA_SOFT_TIMEOUT_MS=12000

# Optional Google Indexing API
GOOGLE_INDEXING_API_ENABLED=false
GOOGLE_INDEXING_API_DRY_RUN=true
GOOGLE_INDEXING_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_INDEXING_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
